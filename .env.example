# Cryptocurrency Intelligence Platform - Environment Variables
# Copy this file to .env and fill in your actual API keys

# Binance Exchange API
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_key_here

# Coinbase Pro API  
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_SECRET=your_coinbase_secret_here
COINBASE_PASSPHRASE=your_coinbase_passphrase_here

# Kraken Exchange API
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_SECRET=your_kraken_secret_here

# Alpha Vantage (Stock/Forex data)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# CoinGecko API (Optional - has free tier)
COINGECKO_API_KEY=your_coingecko_api_key_here

# News API (for sentiment analysis)
NEWS_API_KEY=your_news_api_key_here

# Twitter API (for social sentiment)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Reddit API (for social sentiment) 
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# Database Configuration (if using external DB)
DATABASE_URL=postgresql://username:password@localhost:5432/crypto_db

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379

# Email Configuration (for alerts)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Notification Settings
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Development Settings
DEBUG=True
LOG_LEVEL=INFO

# Model Training Settings
ENABLE_GPU=False
MODEL_SAVE_PATH=./models/
DATA_CACHE_PATH=./data/cache/

# Trading Configuration
DEFAULT_PORTFOLIO_SIZE=100000
DEFAULT_RISK_PER_TRADE=0.02
DEFAULT_STOP_LOSS=0.05
DEFAULT_TAKE_PROFIT=0.10

# Dashboard Configuration
STREAMLIT_PORT=8501
STREAMLIT_HOST=localhost
